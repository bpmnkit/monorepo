{
	"$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
	"organizeImports": {
		"enabled": true
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true
		}
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"lineWidth": 100
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "double",
			"semicolons": "asNeeded"
		}
	},
	"files": {
		"ignore": [
			"node_modules",
			"dist",
			".turbo",
			".swarm",
			"**/templates/generated.ts",
			"**/src-tauri/**",
			"**/.astro/**",
			"**/src/generated/**",
			"**/swagger/**",
			"apps/ai-server-rs/target/**"
		]
	}
}
