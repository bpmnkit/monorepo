{
	"name": "@bpmn-sdk/monorepo",
	"private": true,
	"type": "module",
	"packageManager": "pnpm@10.21.0",
	"scripts": {
		"build": "pnpm turbo build",
		"typecheck": "pnpm turbo typecheck",
		"lint": "biome check .",
		"format": "biome check --write .",
		"test": "pnpm turbo test",
		"check": "pnpm turbo check",
		"verify": "pnpm turbo build typecheck check test",
		"changeset": "changeset",
		"version-packages": "changeset version",
		"release": "pnpm turbo build && changeset publish",
		"update-connectors": "node scripts/update-connectors.mjs",
		"docs:dev": "pnpm --filter @bpmn-sdk/docs dev",
		"docs:build": "pnpm turbo build --filter @bpmn-sdk/docs",
		"ai-server": "pnpm --filter @bpmn-sdk/ai-server start",
		"ai-server-rs": "cargo build --manifest-path apps/ai-server-rs/Cargo.toml && apps/ai-server-rs/target/debug/ai-server",
		"ai-server-rs:build": "cargo build --manifest-path apps/ai-server-rs/Cargo.toml --release",
		"desktop:dev": "pnpm --filter @bpmn-sdk/desktop tauri:dev",
		"desktop:build": "pnpm --filter @bpmn-sdk/desktop tauri:build"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.4",
		"@tauri-apps/cli": "^2",
		"@types/node": "^22.0.0",
		"@changesets/changelog-github": "^0.5.2",
		"@changesets/cli": "^2.29.8",
		"esbuild": "^0.25.0",
		"happy-dom": "^20.7.0",
		"turbo": "^2.4.4",
		"typescript": "^5.7.3",
		"vite": "^7.3.1",
		"vitest": "^3.0.5",
		"wrangler": "^4",
		"astro": "^5",
		"@astrojs/check": "^0.9"
	}
}
