	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.4",
		"@types/node": "^22.0.0",
		"@changesets/changelog-github": "^0.5.2",
		"@changesets/cli": "^2.29.8",
		"happy-dom": "^20.7.0",
		"turbo": "^2.4.4",
		"typescript": "^5.7.3",
		"vite": "^7.3.1",
		"vitest": "^3.0.5"
	}
