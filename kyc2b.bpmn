<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:zeebe="http://camunda.org/schema/zeebe/1.0" id="kyc-process" targetNamespace="http://bpmn.io/schema/bpmn">
  <bpmn:process id="kyc" name="Know Your Customer (KYC) Process" isExecutable="true">
    <bpmn:startEvent id="start" name="Customer Application Received">
      <bpmn:outgoing>f1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:userTask id="collect_info" name="Collect Customer Information">
      <bpmn:incoming>f1</bpmn:incoming>
      <bpmn:outgoing>Flow_e5qpdsl</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="upload_docs" name="Upload Identity Documents">
      <bpmn:incoming>Flow_ee54xme</bpmn:incoming>
      <bpmn:outgoing>f3</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:serviceTask id="verify_docs" name="Verify Documents">
      <bpmn:incoming>f3</bpmn:incoming>
      <bpmn:outgoing>f4</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="check_docs" name="Documents Valid?">
      <bpmn:incoming>f4</bpmn:incoming>
      <bpmn:outgoing>f5</bpmn:outgoing>
      <bpmn:outgoing>f7</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="request_resubmit" name="Request Document Resubmission">
      <bpmn:incoming>f5</bpmn:incoming>
      <bpmn:outgoing>Flow_6j55cdx</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:serviceTask id="identity_check" name="Identity Verification Check">
      <bpmn:incoming>f7</bpmn:incoming>
      <bpmn:outgoing>f8</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="aml_screening" name="AML / Sanctions Screening">
      <bpmn:incoming>f8</bpmn:incoming>
      <bpmn:outgoing>f9</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:businessRuleTask id="risk_assessment" name="Risk Assessment">
      <bpmn:incoming>f9</bpmn:incoming>
      <bpmn:outgoing>f10</bpmn:outgoing>
    </bpmn:businessRuleTask>
    <bpmn:exclusiveGateway id="risk_gateway" name="Risk Level?">
      <bpmn:incoming>f10</bpmn:incoming>
      <bpmn:outgoing>f12</bpmn:outgoing>
      <bpmn:outgoing>Flow_jq9eu0w</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="manual_review" name="Manual Review by Compliance Officer">
      <bpmn:incoming>f12</bpmn:incoming>
      <bpmn:outgoing>f13</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="review_decision" name="Review Decision?">
      <bpmn:incoming>f13</bpmn:incoming>
      <bpmn:outgoing>f15</bpmn:outgoing>
      <bpmn:outgoing>Flow_m5adqmr</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="approve_customer" name="Approve &amp; Onboard Customer">
      <bpmn:incoming>Flow_iilkc6l</bpmn:incoming>
      <bpmn:outgoing>f16</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:userTask id="notify_approved" name="Notify Customer - Approved">
      <bpmn:incoming>f16</bpmn:incoming>
      <bpmn:outgoing>f17</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:serviceTask id="reject_customer" name="Reject Application">
      <bpmn:incoming>f15</bpmn:incoming>
      <bpmn:outgoing>f18</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:userTask id="notify_rejected" name="Notify Customer - Rejected">
      <bpmn:incoming>f18</bpmn:incoming>
      <bpmn:outgoing>f19</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:endEvent id="end_approved" name="Customer Onboarded">
      <bpmn:incoming>f17</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:endEvent id="end_rejected" name="Application Rejected">
      <bpmn:incoming>f19</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:exclusiveGateway id="exclusiveGateway_3u2ji9a">
      <bpmn:incoming>Flow_e5qpdsl</bpmn:incoming>
      <bpmn:incoming>Flow_6j55cdx</bpmn:incoming>
      <bpmn:outgoing>Flow_ee54xme</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:exclusiveGateway id="exclusiveGateway_al9p3j7">
      <bpmn:incoming>Flow_jq9eu0w</bpmn:incoming>
      <bpmn:incoming>Flow_m5adqmr</bpmn:incoming>
      <bpmn:outgoing>Flow_iilkc6l</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sequenceFlow id="f1" sourceRef="start" targetRef="collect_info"/>
    <bpmn:sequenceFlow id="f3" sourceRef="upload_docs" targetRef="verify_docs"/>
    <bpmn:sequenceFlow id="f4" sourceRef="verify_docs" targetRef="check_docs"/>
    <bpmn:sequenceFlow id="f5" sourceRef="check_docs" targetRef="request_resubmit" name="No"/>
    <bpmn:sequenceFlow id="f7" sourceRef="check_docs" targetRef="identity_check" name="Yes"/>
    <bpmn:sequenceFlow id="f8" sourceRef="identity_check" targetRef="aml_screening"/>
    <bpmn:sequenceFlow id="f9" sourceRef="aml_screening" targetRef="risk_assessment"/>
    <bpmn:sequenceFlow id="f10" sourceRef="risk_assessment" targetRef="risk_gateway"/>
    <bpmn:sequenceFlow id="f12" sourceRef="risk_gateway" targetRef="manual_review" name="Medium / High Risk"/>
    <bpmn:sequenceFlow id="f13" sourceRef="manual_review" targetRef="review_decision"/>
    <bpmn:sequenceFlow id="f15" sourceRef="review_decision" targetRef="reject_customer" name="Reject"/>
    <bpmn:sequenceFlow id="f16" sourceRef="approve_customer" targetRef="notify_approved"/>
    <bpmn:sequenceFlow id="f17" sourceRef="notify_approved" targetRef="end_approved"/>
    <bpmn:sequenceFlow id="f18" sourceRef="reject_customer" targetRef="notify_rejected"/>
    <bpmn:sequenceFlow id="f19" sourceRef="notify_rejected" targetRef="end_rejected"/>
    <bpmn:sequenceFlow id="Flow_e5qpdsl" sourceRef="collect_info" targetRef="exclusiveGateway_3u2ji9a"/>
    <bpmn:sequenceFlow id="Flow_ee54xme" sourceRef="exclusiveGateway_3u2ji9a" targetRef="upload_docs"/>
    <bpmn:sequenceFlow id="Flow_6j55cdx" sourceRef="request_resubmit" targetRef="exclusiveGateway_3u2ji9a"/>
    <bpmn:sequenceFlow id="Flow_jq9eu0w" sourceRef="risk_gateway" targetRef="exclusiveGateway_al9p3j7"/>
    <bpmn:sequenceFlow id="Flow_iilkc6l" sourceRef="exclusiveGateway_al9p3j7" targetRef="approve_customer"/>
    <bpmn:sequenceFlow id="Flow_m5adqmr" sourceRef="review_decision" targetRef="exclusiveGateway_al9p3j7"/>
  </bpmn:process>
