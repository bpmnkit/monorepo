      targetRef="TextAnnotation_09d5piu" />
  </bpmn:collaboration>
  <bpmn:process id="optimizeRelease" name="Optimize Release Process" isExecutable="true">
    <bpmn:extensionElements>
      <zeebe:userTaskForm id="userTaskForm_3dnphbf">
        {"schemaVersion":2,"components":[{"text":"#
        Write Blog Post\n[View
        Template](https://docs.google.com/document/d/1fR-slgJ-_fHNaABDPRLQV07l6im_EST_H6LnEWo9h4M/edit#)","type":"text","id":"Field_0a0y92i"}],"type":"default","id":"default1","path":[]}</zeebe:userTaskForm>
      <zeebe:userTaskForm id="userTaskForm_09hbfsn">
        {"schemaVersion":2,"components":[{"text":"#
        Update Enterprise Announcement\n[Camunda Optimize
        Announcements](https://docs.camunda.org/enterprise/announcement/#camunda-optimize-announcements)\n*
        List the next Optimize Minor Release\n* Update the Supported Environments for the current
        release\n(HOW?)","type":"text","id":"Field_1hi5qaj"}],"type":"default","id":"default1","path":[]}</zeebe:userTaskForm>
      <zeebe:userTaskForm id="userTaskForm_13n48dc">{
        "components": [
        {
        "text": "# Come up with a Release Name\nIn the beginning of the month you should think of a
        name for the new release. The name has the following requirements:\n\nIt should be named
        after a superhero.\n\nThe name should represent the new power Optimize gained by this
        release.\n\nCheckout the list of the names that were already picked: [List of old
        Releases](https://confluence.camunda.com/display/CO/Optimize+Release+Overview)\n\nAdd the
        new release to the overview\n\nThis is the most important step, so treat it with
        care!\n\n[Documentation](https://confluence.camunda.com/display/CO/Come+up+with+a+release+name)",
        "type": "text",
        "id": "Field_04nbngm"
        },
        {
        "label": "Release Name",
        "type": "textfield",
        "id": "Field_1lipcjp",
        "key": "releaseName",
        "validate": {
        "required": true
        }
        },
        {
        "values": [
        {
        "label": "Minor",
        "value": "minor"
        },
        {
        "label": "Alpha",
        "value": "alpha"
        },
        {
        "label": "Patch",
        "value": "patch"
        }
        ],
        "label": "Release Type",
        "type": "radio",
        "id": "Field_0out4bk",
        "key": "field_18lgspx",
        "validate": {
        "required": true
        }
        },
        {
        "label": "Release Version",
        "type": "textfield",
        "id": "Field_0gm2fvm",
        "key": "releaseVersion",
        "validate": {
        "required": true
        }
        }
        ],
        "schemaVersion": 4,
        "exporter": {
        "name": "Camunda Web Modeler",
        "version": "24b59bc"
        },
        "type": "default",
        "id": "Form_7e9db25a-a49d-4200-b05b-e2af036b7891",
        "executionPlatform": "Camunda Cloud",
        "executionPlatformVersion": "1.3"
        }</zeebe:userTaskForm>
      <zeebe:userTaskForm id="userTaskForm_0nbf1ge">{
        "components": [
        {
        "text": "# Add Cat Pic of the Month\n\nYou have the honor of picking a cat of the month.
        Why? Because cats are cool, which is proven by the internet (you can just find them
        everywhere). Also this keeps your colleagues motivated, is a symbol for endurance and acts
        as reminder of our responsibility as a software developer and why it's important that we do
        our job. So take this task with care and pride. The quality of the whole release might
        depend on it! (no pressure)\n\nTo get an overview, which cats have already been selected,
        checkout our [Optimize Release
        Overview](https://confluence.camunda.com/display/CO/Optimize+Release+Overview).\n\nOnce you
        are done with finding a new cat:\n\nNext to the Optimize team table, you'll find the
        Optimize Cat Board. This cork board is containing all prestigious cat picture of the month
        pics. Add your choice to it by printing it out and pinning it to the cork board.\nAdd the
        new cat to the [Optimize Release Overview](Optimize Release Overview).",
        "type": "text",
        "id": "Field_0ah92qu"
        },
        {
        "label": "Add cat to Optimize Cat Board",
        "type": "checkbox",
        "id": "Field_1puiaxz",
        "key": "field_103cvfr"
        },
        {
        "label": "Add new cat to Optimize Release Overview",
        "type": "checkbox",
        "id": "Field_00vxrdo",
        "key": "field_156qpt4"
        }
        ],
        "schemaVersion": 4,
        "exporter": {
        "name": "Camunda Web Modeler",
        "version": "24b59bc"
        },
        "type": "default",
        "id": "add-cat-pic",
        "executionPlatform": "Camunda Cloud",
        "executionPlatformVersion": "1.3"
        }</zeebe:userTaskForm>
      <zeebe:userTaskForm id="userTaskForm_1b6iph6">{
        "components": [
        {
        "text": "# Add Optimize to Release Presentation List\nAdd the Optimize release to the
        \"Upcoming release presentations\" table on [this
        page](https://confluence.camunda.com/display/HAN/Release+Presentation+Process), this ensures
        we are included in the release presentation invite agenda",
        "type": "text",
        "id": "Field_01pnkv7"
        }
        ],
        "schemaVersion": 4,
        "exporter": {
        "name": "Camunda Web Modeler",
        "version": "24b59bc"
        },
        "type": "default",
        "id": "Form_9d1890bf-a9b5-4339-9825-20f9623ea7a7",
        "executionPlatform": "Camunda Cloud",
        "executionPlatformVersion": "1.3"
        }</zeebe:userTaskForm>
      <zeebe:userTaskForm id="userTaskForm_3n880kv">{
        "components": [
        {
        "text": "# Set a Calendar
        Appointment\n\n[Documentation](https://confluence.camunda.com/display/CO/Set+a+calendar+appointment)",
        "type": "text",
        "id": "Field_1s8ui1r"
        }
        ],
        "schemaVersion": 4,
        "exporter": {
        "name": "Camunda Web Modeler",
        "version": "24b59bc"
        },
        "type": "default",
        "id": "Form_46707b14-7977-45fd-8d87-bc7f85b66c0a",
        "executionPlatform": "Camunda Cloud",
        "executionPlatformVersion": "1.3"
        }</zeebe:userTaskForm>
      <zeebe:userTaskForm id="userTaskForm_21r2e0l">{
        "components": [
        {
        "text": "# Sync with QA Engineer about upcoming release test activities\n",
        "type": "text",
        "id": "Field_0v7tm4t"
        },
        {
        "label": "Discuss the timeline for the release (code freeze, availability of the release
        candidate, release testing, release date)",
        "type": "checkbox",
        "id": "Field_03p169g",
        "key": "field_1ov635a"
        },
        {
        "label": "Define the features, bug fixes that should be covered in the release test",
        "type": "checkbox",
        "id": "Field_1d0xzc7",
        "key": "field_0v66jn8"
        },
        {
        "label": "Make the developers aware of the release date and until when they are expected to
        have pushed their code / close their tickets so that the new code can make it into the
        release. This could be done in the e.g. weekly status meeting or the optimize internal slack
        channel",
        "type": "checkbox",
        "id": "Field_0cgjoyx",
        "key": "field_0lcvk3t"
        }
        ],
        "schemaVersion": 4,
        "exporter": {
        "name": "Camunda Web Modeler",
        "version": "24b59bc"
        },
        "type": "default",
        "id": "initial-QA-sync",
        "executionPlatform": "Camunda Cloud",
        "executionPlatformVersion": "1.3"
        }</zeebe:userTaskForm>
      <zeebe:userTaskForm id="userTaskForm_29o0otu">{
        "components": [
        {
        "text": "# Remind PM of their tasks\nShare this with the PM on slack:\n\n\"Hey, it's release
        time again! Ready to get started? [PM
        Tasks](https://confluence.camunda.com/display/CO/Release+Tasks+For+Product+Manager)\"",
        "type": "text",
        "id": "Field_0lnlplg"
        }
        ],
        "schemaVersion": 4,
        "exporter": {
        "name": "Camunda Web Modeler",
        "version": "24b59bc"
        },
        "type": "default",
        "id": "remind-PM",
        "executionPlatform": "Camunda Cloud",
        "executionPlatformVersion": "1.3"
        }</zeebe:userTaskForm>
      <zeebe:userTaskForm id="userTaskForm_251m0c0">{
        "components": [
        {
        "text": "# Remind teammates to wrap up development\n\nIn the daily stand-up mention to your
        teammates that:\n1. You would appreciate it if they could finish their reviews and merge
        PR's that should be in the release\n2. If there's still stuff in development that needs to
        be added to the release they should come to you to discuss the details (e.g. when it's
        probably finished, who's reviewing it, etc.) so you can have an estimate by when this is
        finished.\n3. That once done you will be creating the release branch",
        "type": "text",
        "id": "Field_0v2na2g"
        }
        ],
        "schemaVersion": 4,
        "exporter": {
        "name": "Camunda Web Modeler",
        "version": "24b59bc"
        },
        "type": "default",
        "id": "remind-devs-wrapup",
        "executionPlatform": "Camunda Cloud",
        "executionPlatformVersion": "1.3"
        }</zeebe:userTaskForm>
      <zeebe:userTaskForm id="userTaskForm_3mieg50">{
        "components": [
        {
        "text": "# Check Preconditions\nMake sure that:\n\n1. There are no code problems ([check
        ci](https://ci.optimize.camunda.cloud/view/all/job/camunda-optimize/job/master/))\n2. All
        other [ci jobs](https://ci.optimize.camunda.cloud/view/all/) are green and don't show any
        problems.\n3. There are no code tickets in Ready, In Development or Review (see
        [here](https://app.camunda.com/jira/secure/RapidBoard.jspa?rapidView=49&amp;selectedIssue=OPT-165))
        of the \"current release\" lane. If there are tickets left, ask the assigned people to
        finish them or postpone them to the next release. In order to defer those tickets to the
        next release, just remove the label \"current release\" from those Jira Tickets and add the
        label \"next release\". \nTip: After doing the release, you can relabel these tickets in
        bulk by using this [Jira Filter](https://jira.camunda.com/issues/?filter=17863)",
        "type": "text",
        "id": "Field_1147i3d"
        }
        ],
        "schemaVersion": 4,
        "exporter": {
        "name": "Camunda Web Modeler",
        "version": "24b59bc"
        },
        "type": "default",
        "id": "check-preconditions",
        "executionPlatform": "Camunda Cloud",
        "executionPlatformVersion": "1.3"
        }</zeebe:userTaskForm>
      <zeebe:userTaskForm id="userTaskForm_0lbqrif">{
        "components": [],
        "schemaVersion": 4,
        "exporter": {
        "name": "Camunda Web Modeler",
        "version": "24b59bc"
        },
        "type": "default",
        "id": "create-release-branch",
        "executionPlatform": "Camunda Cloud",
        "executionPlatformVersion": "1.3"
        }</zeebe:userTaskForm>
      <zeebe:userTaskForm id="userTaskForm_2mgegi1">{
        "components": [],
