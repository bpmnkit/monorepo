      <zeebe:userTaskForm id="userTaskForm_1fqk5lk">{
        "components": [],
        "schemaVersion": 4,
        "exporter": {
        "name": "Camunda Web Modeler",
        "version": "24b59bc"
        },
        "type": "default",
        "id": "share-download-link",
        "executionPlatform": "Camunda Cloud",
        "executionPlatformVersion": "1.3"
        }</zeebe:userTaskForm>
      <zeebe:userTaskForm id="userTaskForm_2do1uk0">{
        "components": [],
        "schemaVersion": 4,
        "exporter": {
        "name": "Camunda Web Modeler",
        "version": "24b59bc"
        },
        "type": "default",
        "id": "test-release",
        "executionPlatform": "Camunda Cloud",
        "executionPlatformVersion": "1.3"
        }</zeebe:userTaskForm>
      <zeebe:userTaskForm id="userTaskForm_1aldtk3">{
        "components": [],
        "schemaVersion": 4,
        "exporter": {
        "name": "Camunda Web Modeler",
        "version": "24b59bc"
        },
        "type": "default",
        "id": "trigger-final-build",
        "executionPlatform": "Camunda Cloud",
        "executionPlatformVersion": "1.3"
        }</zeebe:userTaskForm>
      <zeebe:userTaskForm id="userTaskForm_1l9jivd">{
        "components": [],
        "schemaVersion": 4,
        "exporter": {
        "name": "Camunda Web Modeler",
        "version": "24b59bc"
        },
        "type": "default",
        "id": "release-jira",
        "executionPlatform": "Camunda Cloud",
        "executionPlatformVersion": "1.3"
        }</zeebe:userTaskForm>
      <zeebe:userTaskForm id="userTaskForm_3s6ldkq">{
        "components": [
        {
        "text": "# Merge the changes of the release branch back to master",
        "type": "text",
        "id": "Field_1qsy7gt"
        }
        ],
        "schemaVersion": 4,
        "exporter": {
        "name": "Camunda Web Modeler",
        "version": "24b59bc"
        },
        "type": "default",
        "id": "merge-release-to-master",
        "executionPlatform": "Camunda Cloud",
        "executionPlatformVersion": "1.3"
        }</zeebe:userTaskForm>
      <zeebe:userTaskForm id="userTaskForm_2a0jmiv">{
        "components": [
        {
        "text": "# Update Third Party library Documentation\n\n1. Go to the root directory of
        camunda-optimize and check out the release branch. Then execute mvn clean install
        -DskipTests -Dskip.docker\n2. Then, go to the [dependency creation
        project](https://github.com/camunda/camunda-optimize/tree/master/util/dependency-doc-creation),
        change into the respective folder and execute the containing script (check that you have the
        [right node
        version](https://github.com/camunda/camunda-optimize/blob/master/client/README.md)
        installed):\n\ncd util/dependency-doc-creation/\n\n./createOptimizeDependencyFiles.sh\n3.
        Now the files backend-dependencies.md and frontend-dependencies.md should have been
        created.\n4. Copy the files to dedicated Optimize
        [frontend](https://github.com/camunda/camunda-platform-docs/blob/master/docs/reference/dependencies.md#optimize-dependencies-front-end)
        and
        [backend](https://github.com/camunda/camunda-platform-docs/blob/master/docs/reference/dependencies.md#optimize-dependencies-back-end)
        sections of the
        [dependencies](https://github.com/camunda/camunda-platform-docs/blob/master/docs/reference/dependencies.md)
        page in the [platform docs](https://github.com/camunda/camunda-platform-docs)",
        "type": "text",
        "id": "Field_1b2evp6"
        }
        ],
        "schemaVersion": 4,
        "exporter": {
        "name": "Camunda Web Modeler",
        "version": "24b59bc"
        },
        "type": "default",
        "id": "update-library-documentation",
        "executionPlatform": "Camunda Cloud",
        "executionPlatformVersion": "1.3"
        }</zeebe:userTaskForm>
      <zeebe:userTaskForm id="userTaskForm_1cbf4h7">{
        "schemaVersion": 2,
        "components": [
        {
        "text": "# Update Enterprise Announcement\n[Camunda Optimize
        Announcements](https://docs.camunda.org/enterprise/announcement/#camunda-optimize-announcements)\n*
        List the next Optimize Minor Release\n* Update the Supported Environments for the current
        release\n(HOW?)",
        "type": "text",
        "id": "Field_1hi5qaj"
        }
        ],
        "type": "default",
        "id": "default1",
        "executionPlatform": "Camunda Cloud",
        "executionPlatformVersion": "1.3"
        }</zeebe:userTaskForm>
      <zeebe:userTaskForm id="userTaskForm_212rons">{
        "components": [
        {
        "text": "# Update Whatsnew\nUpdate the \"What's new\" dialog \n\nNote: This should be done
        at least 4 days before the release! Even better would be the week before.\n\nCheck out all
        the new features that will be added for the upcoming release. Once you have an overview make
        sure that:\n\n1. all the features are included in the What's new dialog\n2. same goes for
        the german version\n3. polish the dialog by proofreading it together with the product
        marketing/product design team\n4. create a ticket (clone
        https://jira.camunda.com/browse/OPT-5638)\n5. create a PR for the necessary changes in the
        dialog and assign it to one of the developers.",
        "type": "text",
        "id": "Field_15rosh7"
        },
        {
        "label": "Whatsnew Ticket URL",
        "type": "textfield",
        "id": "Field_1ogpqvc",
        "key": "whatsnew-ticket-url",
        "description": "e.g. https://jira.camunda.com/browse/OPT-5638",
        "validate": {
        "required": true
        }
        }
        ],
        "schemaVersion": 4,
        "exporter": {
        "name": "Camunda Web Modeler",
        "version": "e73c95f"
        },
        "type": "default",
        "id": "update-whatsnew",
        "executionPlatform": "Camunda Cloud",
        "executionPlatformVersion": "1.3"
        }</zeebe:userTaskForm>
      <zeebe:userTaskForm id="UserTaskForm_28mdt1t">{
        "components": [
        {
        "text": "# Remind PM of their tasks\nShare this with the PM on slack:\n\n\"Hey, it's release
        time again! Ready to get started? [PM
        Tasks](https://confluence.camunda.com/display/CO/Release+Tasks+For+Product+Manager)\"",
        "type": "text",
        "id": "Field_0lnlplg"
        }
        ],
        "schemaVersion": 4,
        "exporter": {
        "name": "Camunda Web Modeler",
        "version": "24b59bc"
        },
        "type": "default",
        "id": "remind-PM",
        "executionPlatform": "Camunda Cloud",
        "executionPlatformVersion": "1.3"
        }</zeebe:userTaskForm>
      <zeebe:userTaskForm id="userTaskForm_268ieai">{
        "components": [
        {
        "text": "# Update the current release ticket list\nCheck the tickets in the [Jira
        filter](https://jira.camunda.com/issues/?filter=17864) and find out which tickets will be
        part of the release.\n\nRemove the \"current release\" label from tickets that won't make
        it.",
        "type": "text",
        "id": "Field_1s5rpnh"
        }
        ],
        "schemaVersion": 4,
        "exporter": {
        "name": "Camunda Web Modeler",
        "version": "e73c95f"
        },
        "type": "default",
        "id": "update-current_release",
        "executionPlatform": "Camunda Cloud",
        "executionPlatformVersion": "1.3"
        }</zeebe:userTaskForm>
      <zeebe:userTaskForm id="userTaskForm_390mro6">{
        "components": [
        {
        "text": "# PM Release Preparation\nReview [Confirmed
        Blog](https://jira.camunda.com/issues/?filter=17518)\n\nReview [Potential
        Blog](https://jira.camunda.com/issues/?filter=17519)",
        "type": "text",
        "id": "Field_1nnegby"
        },
        {
        "label": "What are the main takeaways from the release?",
        "type": "textfield",
        "id": "Field_0agbrwv",
        "key": "mainTakeaways"
        },
        {
        "text": "# Due Dates \nAll due dates are measured in work days\n* What's New dialog (minor
        only): 4 days before release\n* Blog Post: 3 days before release\n* Release Presentation
        Slides: 1 day before release\n\n[Product Manager
        Instructions](https://confluence.camunda.com/display/CO/Release+Tasks+For+Product+Manager)",
        "type": "text",
        "id": "Field_19wzklp"
        }
        ],
        "schemaVersion": 4,
        "type": "default",
        "id": "pm-release-prep",
        "executionPlatform": "Camunda Cloud",
        "executionPlatformVersion": "1.3",
        "exporter": {
        "name": "Camunda Web Modeler",
        "version": "e73c95f"
        }
        }</zeebe:userTaskForm>
      <zeebe:userTaskForm id="userTaskForm_06fen59">{
        "components": [
        {
        "text": "# Share Blog Post with Marketing\nPing the Marketing POC via the draft blogpost
        that it's ready for editing and follow up via Slack",
        "type": "text",
        "id": "Field_17h7nqc"
        }
        ],
        "schemaVersion": 4,
        "exporter": {
        "name": "Camunda Web Modeler",
        "version": "e73c95f"
        },
        "type": "default",
        "id": "share-blogpost",
        "executionPlatform": "Camunda Cloud",
        "executionPlatformVersion": "1.3"
        }</zeebe:userTaskForm>
      <zeebe:userTaskForm id="userTaskForm_0ifka4n">{
        "components": [
        {
        "text": "# Fix Bugs\nAddress all bugs discovered during release testing",
        "type": "text",
        "id": "Field_1n194tc"
        }
        ],
        "schemaVersion": 4,
        "exporter": {
        "name": "Camunda Web Modeler",
        "version": "e73c95f"
        },
        "type": "default",
        "id": "fix-bugs",
        "executionPlatform": "Camunda Cloud",
        "executionPlatformVersion": "1.3"
