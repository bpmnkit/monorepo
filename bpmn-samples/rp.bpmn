      <zeebe:userTaskForm id="userTaskForm_2g80aao">{
        "components": [
        {
        "text": "# Notify PM / Prod Ops of Blog Post\n1. Share the blog post URL with the Product
        Manager\n2. Share the blog post URL with the Product Operations",
        "type": "text",
        "id": "Field_0y14qts"
        },
        {
        "label": "Blog Post URL",
        "type": "textfield",
