{
	"name": "@bpmnkit/profiles",
	"version": "0.0.9",
	"description": "Shared auth, profile storage, and client factories for the BPMN Kit CLI and proxy server",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"import": "./dist/index.js",
			"types": "./dist/index.d.ts"
		}
	},
	"files": ["LICENSE", "README.md", "dist/**/*.js", "dist/**/*.d.ts"],
	"engines": {
		"node": ">=20"
	},
	"scripts": {
		"build": "tsc",
		"typecheck": "tsc --noEmit",
		"check": "biome check ."
	},
	"dependencies": {
		"@bpmnkit/api": "workspace:*"
	},
	"keywords": ["bpmn", "camunda", "profiles", "authentication", "oauth2", "cli", "typescript"],
	"publishConfig": {
		"access": "public"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/bpmnkit/monorepo"
	},
	"license": "MIT",
	"homepage": "https://bpmnkit.com",
	"bugs": {
		"url": "https://github.com/bpmnkit/monorepo/issues"
	}
}
