{
	"name": "@bpmn-sdk/canvas",
	"version": "0.0.6",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"files": [
		"dist/**/*.js",
		"dist/**/*.d.ts"
	],
	"scripts": {
		"build": "tsc",
		"typecheck": "tsc --noEmit",
		"check": "biome check .",
		"test": "vitest run"
	},
	"dependencies": {
		"@bpmn-sdk/core": "workspace:*"
	},
	"description": "Zero-dependency SVG BPMN viewer with pan/zoom, theming, and a plugin API",
	"keywords": [
		"bpmn",
		"viewer",
		"svg",
		"canvas",
		"workflow",
		"typescript"
	],
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/bpmn-sdk/monorepo"
	}
