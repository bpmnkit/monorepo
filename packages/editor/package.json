{
	"name": "@bpmn-sdk/editor",
	"version": "0.0.5",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"files": ["dist/**/*.js", "dist/**/*.d.ts"],
	"scripts": {
		"build": "tsc",
		"typecheck": "tsc --noEmit",
		"check": "biome check .",
		"test": "vitest run"
	},
	"dependencies": {
		"@bpmn-sdk/canvas": "workspace:*",
		"@bpmn-sdk/core": "workspace:*"
	},
	"description": "Full-featured interactive BPMN editor with undo/redo, HUD, and side-dock UI",
	"keywords": ["bpmn", "editor", "workflow", "typescript", "canvas"],
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/bpmn-sdk/monorepo"
	}
}
