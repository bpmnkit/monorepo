{
	"name": "@bpmnkit/editor",
	"version": "0.0.11",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"files": ["LICENSE", "README.md", "dist/**/*.js", "dist/**/*.d.ts"],
	"scripts": {
		"build": "tsc",
		"typecheck": "tsc --noEmit",
		"check": "biome check .",
		"test": "vitest run"
	},
	"dependencies": {
		"@bpmnkit/canvas": "workspace:*",
		"@bpmnkit/core": "workspace:*"
	},
	"description": "Full-featured interactive BPMN editor with undo/redo, HUD, and side-dock UI",
	"keywords": ["bpmn", "editor", "workflow", "typescript", "canvas", "camunda"],
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/bpmnkit/monorepo"
	},
	"homepage": "https://bpmnkit.com",
	"bugs": {
		"url": "https://github.com/bpmnkit/monorepo/issues"
	},
	"publishConfig": {
		"access": "public"
	}
}
