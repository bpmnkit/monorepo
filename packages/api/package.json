{
	"name": "@bpmn-sdk/api",
	"version": "0.0.8",
	"private": false,
	"type": "module",
	"exports": {
		".": {
			"import": "./dist/index.js",
			"types": "./dist/index.d.ts"
		}
	},
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"files": [
		"dist/**/*.js",
		"dist/**/*.d.ts"
	],
	"scripts": {
		"generate": "node scripts/generate.mjs",
		"generate:admin": "node scripts/generate.mjs --api admin",
		"build": "node scripts/generate.mjs && node scripts/generate.mjs --api admin && tsc",
		"typecheck": "tsc --noEmit",
		"check": "biome check .",
		"test": "vitest run"
	},
	"dependencies": {},
	"description": "TypeScript client for the Camunda 8 REST API — 180 typed operations, OAuth2, retries, and caching",
	"keywords": [
		"camunda",
		"zeebe",
		"bpmn",
		"api",
		"client",
		"rest",
		"typescript"
	],
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/bpmn-sdk/monorepo"
	}
}
