{
	"name": "@bpmn-sdk/ascii",
	"version": "0.0.8",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"files": [
		"dist/**/*.js",
		"dist/**/*.d.ts"
	],
	"scripts": {
		"build": "tsc",
		"typecheck": "tsc --noEmit",
		"check": "biome check .",
		"test": "vitest run"
	},
	"dependencies": {
		"@bpmn-sdk/core": "workspace:*"
	},
	"description": "Render BPMN diagrams as Unicode box-drawing ASCII art — perfect for terminals and docs",
	"keywords": [
		"bpmn",
		"ascii",
		"terminal",
		"diagram",
		"typescript"
	],
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/bpmn-sdk/monorepo"
	}
}
