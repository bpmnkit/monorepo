        <di:waypoint x="900" y="200"/>
        <di:waypoint x="900" y="262"/>
        <di:waypoint x="1050" y="262"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f8_di" bpmnElement="f8">
        <di:waypoint x="1150" y="262"/>
        <di:waypoint x="1250" y="262"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f9_di" bpmnElement="f9">
        <di:waypoint x="1350" y="262"/>
        <di:waypoint x="1450" y="262"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f10_di" bpmnElement="f10">
        <di:waypoint x="1550" y="262"/>
        <di:waypoint x="1682" y="262"/>
        <di:waypoint x="1682" y="204"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f11_di" bpmnElement="f11">
        <di:waypoint x="1700" y="186"/>
        <di:waypoint x="1700" y="226"/>
        <di:waypoint x="2250" y="226"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f12_di" bpmnElement="f12">
        <di:waypoint x="1700" y="222"/>
        <di:waypoint x="1700" y="284"/>
        <di:waypoint x="1850" y="284"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f13_di" bpmnElement="f13">
        <di:waypoint x="1950" y="284"/>
        <di:waypoint x="2082" y="284"/>
        <di:waypoint x="2082" y="306"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f14_di" bpmnElement="f14">
        <di:waypoint x="2100" y="288"/>
        <di:waypoint x="2100" y="226"/>
        <di:waypoint x="2250" y="226"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f15_di" bpmnElement="f15">
        <di:waypoint x="2100" y="324"/>
        <di:waypoint x="2100" y="386"/>
        <di:waypoint x="2250" y="386"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f16_di" bpmnElement="f16">
        <di:waypoint x="2350" y="226"/>
        <di:waypoint x="2450" y="226"/>
