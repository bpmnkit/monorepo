  <script is:inline>
    // Nav burger
    (function () {
      var btn = document.getElementById('nav-burger');
      var menu = document.getElementById('nav-mobile-menu');
      if (!btn || !menu) return;
      btn.addEventListener('click', function () {
        var open = btn.getAttribute('aria-expanded') === 'true';
        btn.setAttribute('aria-expanded', String(!open));
        menu.setAttribute('aria-hidden', String(open));
      });
    })();

    // Install cmd copy
    (function () {
      var copyBtn = document.getElementById('copy-btn');
      var cmdEl = document.getElementById('install-cmd');
      if (!copyBtn || !cmdEl) return;
      copyBtn.addEventListener('click', function () {
        navigator.clipboard.writeText(cmdEl.textContent || '').then(function () {
          copyBtn.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>';
          setTimeout(function () {
            copyBtn.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>';
          }, 1500);
        });
      });
    })();

    // Install tabs
    (function () {
      var tabs = document.querySelectorAll('.cli-pkg-tab');
      var cmds = document.querySelectorAll('.cli-pkg-cmd');
      tabs.forEach(function (tab) {
        tab.addEventListener('click', function () {
          var pkg = tab.dataset.pkg;
          tabs.forEach(function (t) { t.classList.remove('active'); });
          cmds.forEach(function (c) { c.classList.remove('active'); });
          tab.classList.add('active');
          var cmd = document.querySelector('.cli-pkg-cmd[data-pkg="' + pkg + '"]');
          if (cmd) cmd.classList.add('active');
        });
      });
    })();
  </script>
