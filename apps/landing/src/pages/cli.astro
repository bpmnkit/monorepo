---
import "../styles/global.css"
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>casen CLI — Manage Camunda 8 from your terminal · BPMN Kit</title>
  <meta name="description" content="casen is the official command-line interface for Camunda 8. Deploy processes, manage incidents, query instances, and generate connectors — all from your terminal." />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/asciinema-player@3/dist/bundle/player.min.css" />
  <style is:global>
    /* ── Page layout ────────────────────────────────────────────────── */
    .cli-page-wrap {
      min-height: 100dvh;
      display: flex;
      flex-direction: column;
    }

    /* ── Hero ───────────────────────────────────────────────────────── */
    .cli-hero {
      padding: calc(var(--nav-h) + 80px) 24px 72px;
      text-align: center;
    }

    .cli-hero-eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      font-size: 12px;
      font-weight: 600;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--teal);
      margin-bottom: 20px;
    }

    .cli-hero-eyebrow-dot {
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: var(--teal);
      animation: eyebrow-pulse 2s ease-in-out infinite alternate;
    }

    @keyframes eyebrow-pulse {
      from { opacity: 1; transform: scale(1); }
      to   { opacity: 0.3; transform: scale(0.7); }
    }

    .cli-hero-title {
      font-size: clamp(3.5rem, 10vw, 6rem);
      font-weight: 800;
      line-height: 1;
      letter-spacing: -0.04em;
      margin-bottom: 24px;
    }

    .cli-hero-title .shimmer-text {
      font-family: var(--font-mono);
    }

    .cli-hero-sub {
      font-size: clamp(1rem, 2.5vw, 1.2rem);
      color: var(--text-muted);
      max-width: 560px;
      margin: 0 auto 40px;
      line-height: 1.7;
    }

    .cli-install-box {
      display: inline-flex;
      align-items: center;
      gap: 12px;
      background: var(--bg-code);
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 12px 20px;
      font-family: var(--font-mono);
      font-size: 14px;
      margin-bottom: 32px;
    }

    .cli-install-prompt {
      color: var(--teal);
      user-select: none;
    }

    .cli-install-cmd {
      color: var(--text);
    }

    .cli-install-copy {
      background: none;
      border: none;
      color: var(--text-muted);
      cursor: pointer;
      padding: 2px 6px;
      border-radius: 4px;
      transition: color 0.2s, background 0.2s;
    }

    .cli-install-copy:hover {
      color: var(--text);
      background: var(--border);
    }

    .cli-hero-ctas {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 12px;
      flex-wrap: wrap;
    }

    /* ── Demo / asciinema ───────────────────────────────────────────── */
    .cli-demo-section {
      padding: 0 24px 80px;
    }

    .cli-demo-inner {
      max-width: 900px;
      margin: 0 auto;
    }

    .cli-demo-player {
      border-radius: 12px;
      overflow: hidden;
      border: 1px solid var(--border);
      box-shadow: 0 24px 80px oklch(0% 0 0 / 0.5);
    }

    /* Override asciinema player chrome to match our theme */
    .cli-demo-player .ap-player {
      border-radius: 12px;
    }

    .cli-demo-caption {
      text-align: center;
      margin-top: 14px;
      font-size: 13px;
      color: var(--text-muted);
    }

    /* ── Features grid ──────────────────────────────────────────────── */
    .cli-feat-section {
      padding: 80px 24px;
    }

    .cli-feat-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
      gap: 16px;
      margin-top: 48px;
    }

    .cli-feat-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 28px;
      transition: border-color 0.2s, box-shadow 0.2s;
    }

    .cli-feat-card:hover {
      border-color: oklch(55% 0.22 280 / 0.4);
      box-shadow: 0 8px 32px oklch(55% 0.22 280 / 0.06);
    }

    .cli-feat-icon {
      width: 40px;
      height: 40px;
      border-radius: 10px;
      background: oklch(55% 0.22 280 / 0.1);
      border: 1px solid oklch(55% 0.22 280 / 0.2);
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--accent-bright);
      margin-bottom: 16px;
    }

    .cli-feat-card h3 {
      font-size: 15px;
      font-weight: 600;
      color: var(--text);
      margin-bottom: 8px;
    }

    .cli-feat-card p {
      font-size: 13.5px;
      color: var(--text-muted);
      line-height: 1.6;
    }

    /* ── Commands reference ─────────────────────────────────────────── */
    .cli-cmds-section {
      padding: 80px 24px;
    }

    .cli-cmds-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
      gap: 24px;
      margin-top: 48px;
    }

    .cli-cmd-group {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      overflow: hidden;
    }

    .cli-cmd-group-header {
      padding: 14px 20px;
      background: oklch(12% 0.025 270);
      border-bottom: 1px solid var(--border);
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .cli-cmd-group-icon {
      color: var(--teal);
    }

    .cli-cmd-group-title {
      font-size: 13px;
      font-weight: 600;
      color: var(--text);
      letter-spacing: 0.02em;
      text-transform: uppercase;
    }

    .cli-cmd-table {
      width: 100%;
      border-collapse: collapse;
    }

    .cli-cmd-table tr {
      border-bottom: 1px solid var(--border);
    }

    .cli-cmd-table tr:last-child {
      border-bottom: none;
    }

    .cli-cmd-table tr:hover {
      background: oklch(12% 0.025 270 / 0.5);
    }

    .cli-cmd-table td {
      padding: 10px 20px;
      font-size: 13px;
      vertical-align: middle;
    }

    .cli-cmd-table td:first-child {
      font-family: var(--font-mono);
      color: var(--teal);
      white-space: nowrap;
      width: 1%;
      padding-right: 8px;
    }

    .cli-cmd-table td:last-child {
      color: var(--text-muted);
    }

    /* ── Output formats ─────────────────────────────────────────────── */
    .cli-output-section {
      padding: 80px 24px;
    }

    .cli-output-layout {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 24px;
      margin-top: 48px;
    }

    @media (max-width: 720px) {
      .cli-output-layout {
        grid-template-columns: 1fr;
      }
    }

    .cli-output-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      overflow: hidden;
    }

    .cli-output-card-header {
      padding: 12px 20px;
      background: oklch(12% 0.025 270);
      border-bottom: 1px solid var(--border);
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .cli-output-card-title {
      font-size: 12px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--text-muted);
    }

    .cli-output-flag {
      font-family: var(--font-mono);
      font-size: 11px;
      color: var(--teal);
      background: oklch(72% 0.18 185 / 0.1);
      border: 1px solid oklch(72% 0.18 185 / 0.2);
      border-radius: 4px;
      padding: 2px 8px;
    }

    .cli-output-card pre {
      padding: 20px;
      margin: 0;
      font-size: 12.5px;
      line-height: 1.7;
      color: var(--text-muted);
      font-family: var(--font-mono);
      overflow-x: auto;
    }

    .cli-output-card pre .k { color: var(--accent-bright); }
    .cli-output-card pre .s { color: oklch(72% 0.18 185); }
    .cli-output-card pre .n { color: oklch(80% 0.18 60); }
    .cli-output-card pre .h { color: var(--text-muted); font-style: italic; }

    /* ── Global flags ───────────────────────────────────────────────── */
    .cli-flags-section {
      padding: 80px 24px;
    }

    .cli-flags-table {
      width: 100%;
      border-collapse: collapse;
      margin-top: 32px;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      overflow: hidden;
    }

    .cli-flags-table thead tr {
      background: oklch(12% 0.025 270);
    }

    .cli-flags-table th {
      padding: 12px 20px;
      font-size: 11px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--text-muted);
      text-align: left;
      border-bottom: 1px solid var(--border);
    }

    .cli-flags-table td {
      padding: 12px 20px;
      font-size: 13px;
      border-bottom: 1px solid oklch(15% 0.03 270 / 0.5);
      vertical-align: middle;
    }

    .cli-flags-table tr:last-child td {
      border-bottom: none;
    }

    .cli-flags-table td:first-child {
      font-family: var(--font-mono);
      color: var(--teal);
      white-space: nowrap;
    }

    .cli-flags-table td:nth-child(2) {
      color: var(--text-muted);
      font-size: 12.5px;
      font-family: var(--font-mono);
    }

    .cli-flags-table td:last-child {
      color: var(--text-muted);
    }

    /* ── Shell completion ───────────────────────────────────────────── */
    .cli-completion-section {
      padding: 80px 24px;
    }

    .cli-completion-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 16px;
      margin-top: 48px;
    }

    @media (max-width: 720px) {
      .cli-completion-grid {
        grid-template-columns: 1fr;
      }
    }

    .cli-completion-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      overflow: hidden;
    }

    .cli-completion-card-header {
      padding: 12px 20px;
      background: oklch(12% 0.025 270);
      border-bottom: 1px solid var(--border);
      font-size: 13px;
      font-weight: 600;
      color: var(--text);
    }

    .cli-completion-card pre {
      padding: 16px 20px;
      margin: 0;
      font-size: 12.5px;
      font-family: var(--font-mono);
      color: var(--text-muted);
      line-height: 1.7;
    }

    .cli-completion-card pre .c { color: var(--text-muted); opacity: 0.5; }
    .cli-completion-card pre .cmd { color: var(--teal); }

    /* ── Install ────────────────────────────────────────────────────── */
    .cli-install-section {
      padding: 80px 24px 120px;
    }

    .cli-install-tabs-wrap {
      max-width: 560px;
      margin: 48px auto 0;
    }

    .cli-pkg-tabs {
      display: flex;
      gap: 4px;
      margin-bottom: 12px;
    }

    .cli-pkg-tab {
      background: none;
      border: 1px solid transparent;
      border-radius: 8px;
      padding: 6px 14px;
      font-size: 13px;
      font-weight: 500;
      color: var(--text-muted);
      cursor: pointer;
      transition: color 0.2s, background 0.2s, border-color 0.2s;
    }

    .cli-pkg-tab:hover {
      color: var(--text);
      background: oklch(15% 0.03 270 / 0.5);
    }

    .cli-pkg-tab.active {
      color: var(--text);
      background: var(--surface);
      border-color: var(--border);
    }

    .cli-pkg-cmd {
      display: none;
      background: var(--bg-code);
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 16px 20px;
      font-family: var(--font-mono);
      font-size: 14px;
      color: var(--text);
    }

    .cli-pkg-cmd.active {
      display: block;
    }

    .cli-pkg-cmd .prompt {
      color: var(--teal);
      user-select: none;
    }

    /* ── Responsive ─────────────────────────────────────────────────── */
    @media (max-width: 640px) {
      .cli-feat-grid {
        grid-template-columns: 1fr;
      }

      .cli-cmds-grid {
        grid-template-columns: 1fr;
      }
    }

    /* .shimmer-text — defined in global.css */
  </style>
</head>
