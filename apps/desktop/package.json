{
	"name": "@bpmn-sdk/desktop",
	"private": true,
	"version": "0.1.5",
	"type": "module",
	"scripts": {
		"dev": "vite --port 1420 --strictPort",
		"build": "vite build",
		"typecheck": "tsc --noEmit",
		"check": "biome check .",
		"tauri:dev": "tauri dev",
		"tauri:build": "cargo build --manifest-path ../../apps/proxy-rs/Cargo.toml --release && tauri build"
	},
	"dependencies": {
		"@bpmn-sdk/canvas": "workspace:*",
		"@bpmn-sdk/plugins": "workspace:*",
		"@bpmn-sdk/core": "workspace:*",
		"@bpmn-sdk/editor": "workspace:*"
	}
}
