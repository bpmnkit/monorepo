{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "BPMN SDK Editor",
  "version": "0.1.0",
  "identifier": "dev.bpmnsdk.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "BPMN SDK Editor",
        "width": 1440,
        "height": 900,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/256x256.png"],
    "resources": {
      "../../ai-server/dist/bundle.cjs": "ai-server.cjs"
    }
  }
}
