  targetNamespace="http://bpmn.io/schema/bpmn">
  <bpmn:process id="Process_a46jeg0" name="New Process" isExecutable="true">
    <bpmn:startEvent id="start" name="Application Submitted">
      <bpmn:outgoing>f1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:userTask id="task_collect_docs" name="Collect identity documents">
      <bpmn:incoming>f1</bpmn:incoming>
      <bpmn:outgoing>f2</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:serviceTask id="task_verify_identity" name="Verify identity data">
      <bpmn:incoming>f2</bpmn:incoming>
      <bpmn:outgoing>f3</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="gw_docs_valid" name="Documents valid?">
      <bpmn:incoming>f3</bpmn:incoming>
      <bpmn:outgoing>f4</bpmn:outgoing>
      <bpmn:outgoing>f5</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="task_request_resubmit" name="Request document resubmission">
      <bpmn:incoming>f5</bpmn:incoming>
      <bpmn:outgoing>f6</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="gw_resubmit_join">
      <bpmn:incoming>f4</bpmn:incoming>
      <bpmn:incoming>f6</bpmn:incoming>
      <bpmn:outgoing>f7</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="task_sanctions" name="Screen against sanctions list">
      <bpmn:incoming>f7</bpmn:incoming>
      <bpmn:outgoing>f8</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="task_pep_check" name="Check PEP status">
      <bpmn:incoming>f8</bpmn:incoming>
      <bpmn:outgoing>f9</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="task_aml_check" name="Run AML risk assessment">
      <bpmn:incoming>f9</bpmn:incoming>
      <bpmn:outgoing>f10</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="task_risk_score" name="Calculate risk score">
      <bpmn:incoming>f10</bpmn:incoming>
      <bpmn:outgoing>f11</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="gw_risk_level" name="Risk level?">
      <bpmn:incoming>f11</bpmn:incoming>
      <bpmn:outgoing>f12</bpmn:outgoing>
      <bpmn:outgoing>f13</bpmn:outgoing>
      <bpmn:outgoing>f14</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="task_auto_approve" name="Auto-approve customer">
      <bpmn:incoming>f12</bpmn:incoming>
      <bpmn:outgoing>f15</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:userTask id="task_enhanced_review" name="Perform enhanced due diligence">
      <bpmn:incoming>f13</bpmn:incoming>
      <bpmn:outgoing>f16</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="gw_review_decision" name="Review approved?">
      <bpmn:incoming>f16</bpmn:incoming>
      <bpmn:outgoing>f17</bpmn:outgoing>
      <bpmn:outgoing>f18</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="task_reject" name="Notify customer of rejection">
      <bpmn:incoming>f14</bpmn:incoming>
      <bpmn:incoming>f18</bpmn:incoming>
      <bpmn:outgoing>f22</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="gw_approved_join">
      <bpmn:incoming>f15</bpmn:incoming>
      <bpmn:incoming>f17</bpmn:incoming>
      <bpmn:outgoing>f19</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="task_onboard" name="Onboard customer">
      <bpmn:incoming>f19</bpmn:incoming>
      <bpmn:outgoing>f20</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:serviceTask id="task_notify_approval" name="Send approval notification">
      <bpmn:incoming>f20</bpmn:incoming>
      <bpmn:outgoing>f21</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="end_approved" name="Customer Onboarded">
      <bpmn:incoming>f21</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:endEvent id="end_rejected" name="Application Rejected">
      <bpmn:incoming>f22</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="f1" sourceRef="start" targetRef="task_collect_docs" />
    <bpmn:sequenceFlow id="f2" sourceRef="task_collect_docs" targetRef="task_verify_identity" />
    <bpmn:sequenceFlow id="f3" sourceRef="task_verify_identity" targetRef="gw_docs_valid" />
    <bpmn:sequenceFlow id="f4" sourceRef="gw_docs_valid" targetRef="gw_resubmit_join" name="Yes" />
    <bpmn:sequenceFlow id="f5" sourceRef="gw_docs_valid" targetRef="task_request_resubmit" name="No" />
    <bpmn:sequenceFlow id="f6" sourceRef="task_request_resubmit" targetRef="gw_resubmit_join" />
    <bpmn:sequenceFlow id="f7" sourceRef="gw_resubmit_join" targetRef="task_sanctions" />
    <bpmn:sequenceFlow id="f8" sourceRef="task_sanctions" targetRef="task_pep_check" />
    <bpmn:sequenceFlow id="f9" sourceRef="task_pep_check" targetRef="task_aml_check" />
    <bpmn:sequenceFlow id="f10" sourceRef="task_aml_check" targetRef="task_risk_score" />
    <bpmn:sequenceFlow id="f11" sourceRef="task_risk_score" targetRef="gw_risk_level" />
    <bpmn:sequenceFlow id="f12" sourceRef="gw_risk_level" targetRef="task_auto_approve" name="Low" />
    <bpmn:sequenceFlow id="f13" sourceRef="gw_risk_level" targetRef="task_enhanced_review"
      name="Medium" />
    <bpmn:sequenceFlow id="f14" sourceRef="gw_risk_level" targetRef="task_reject" name="High" />
    <bpmn:sequenceFlow id="f15" sourceRef="task_auto_approve" targetRef="gw_approved_join" />
    <bpmn:sequenceFlow id="f16" sourceRef="task_enhanced_review" targetRef="gw_review_decision" />
    <bpmn:sequenceFlow id="f17" sourceRef="gw_review_decision" targetRef="gw_approved_join"
      name="Yes" />
    <bpmn:sequenceFlow id="f18" sourceRef="gw_review_decision" targetRef="task_reject" name="No" />
    <bpmn:sequenceFlow id="f19" sourceRef="gw_approved_join" targetRef="task_onboard" />
    <bpmn:sequenceFlow id="f20" sourceRef="task_onboard" targetRef="task_notify_approval" />
    <bpmn:sequenceFlow id="f21" sourceRef="task_notify_approval" targetRef="end_approved" />
    <bpmn:sequenceFlow id="f22" sourceRef="task_reject" targetRef="end_rejected" />
  </bpmn:process>
